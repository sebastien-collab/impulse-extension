{
  "manifest_version": 3,
  "name": "Media Buyer Helper",
  "description": "Universal pixel debugger and tech stack detector. Verify tracking implementations, check consent mode, and inspect any webpage.",
  "version": "2.3.0",

  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "Media Buyer Helper — Pixel Debugger"
  },

  "background": {
    "service_worker": "background/service-worker.js"
  },

  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content/content.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],

  "permissions": [
    "webRequest",
    "activeTab",
    "scripting",
    "storage",
    "cookies",
    "browsingData"
  ],

  "host_permissions": [
    "*://www.googletagmanager.com/*",
    "*://www.google-analytics.com/*",
    "*://analytics.google.com/*",
    "*://googleads.g.doubleclick.net/*",
    "*://www.googleadservices.com/*",
    "*://connect.facebook.net/*",
    "*://www.facebook.com/*",
    "*://analytics.tiktok.com/*",
    "*://px.ads.linkedin.com/*",
    "*://snap.licdn.com/*",
    "*://ads.linkedin.com/*",
    "*://ct.pinterest.com/*",
    "*://s.pinimg.com/*",
    "*://tr.snapchat.com/*",
    "*://sc-static.net/*",
    "*://static.ads-twitter.com/*",
    "*://analytics.twitter.com/*",
    "*://bat.bing.com/*",
    "*://t.co/*"
  ],

  "web_accessible_resources": [
    {
      "resources": ["content/injected.js", "shared/pixels.js", "shared/techstack.js"],
      "matches": ["http://*/*", "https://*/*"]
    }
  ]
}
