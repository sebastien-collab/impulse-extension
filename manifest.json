{
  "manifest_version": 3,
  "name": "Impulse",
  "description": "Universal pixel & tag debugger for media buyers. Detect GTM, GA4, Meta, TikTok, LinkedIn, Pinterest, Snapchat, X, Bing & more.",
  "version": "1.0.0",

  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "Impulse — Pixel Debugger"
  },

  "background": {
    "service_worker": "background/service-worker.js"
  },

  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content/content.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],

  "permissions": [
    "webRequest",
    "activeTab",
    "scripting",
    "storage"
  ],

  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],

  "web_accessible_resources": [
    {
      "resources": ["content/injected.js", "shared/pixels.js"],
      "matches": ["http://*/*", "https://*/*"]
    }
  ]
}
